# Sentinel Configuration
# Copy this file to .env and fill in your API keys

# ===================
# REQUIRED
# ===================

# Mistral AI - Get from https://console.mistral.ai/
MISTRAL_API_KEY=

# ===================
# OPTIONAL
# ===================

# Polymarket (CLOB API - public data works without auth)
# For authenticated endpoints, get from https://polymarket.com
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=

# ===================
# OSINT SOURCES (from worldmonitor)
# ===================

# ACLED - Armed Conflict Data
# Get from https://acleddata.com/
ACLED_ACCESS_TOKEN=

# NASA FIRMS - Fire Detection
# Get from https://firms.modaps.eosdis.nasa.gov/api/
NASA_FIRMS_API_KEY=

# OpenSky Network - Aviation Tracking (optional)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# AISStream - Maritime Tracking (optional)
AISSTREAM_API_KEY=

# Weights & Biases - for model tracing
# Get from https://wandb.ai/settings
WANDB_API_KEY=

# ElevenLabs - for voice alerts
# Get from https://elevenlabs.io/
ELEVENLABS_API_KEY=

# ===================
# LOCAL CONFIG
# ===================

# Database path (relative to project root)
DATABASE_PATH=./data/sentinel.db

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./data/chroma

# GDELT API (free, no key needed)
GDELT_API_URL=https://api.gdeltproject.org/api/v2/
